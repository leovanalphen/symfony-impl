{
    "name": "symphony/symphony",
    "description": "Symphony - Long-running automation service for Linear issues and Codex agent",
    "type": "project",
    "require": {
        "php": "^8.3",
        "symfony/console": "^7.0",
        "symfony/yaml": "^7.0",
        "twig/twig": "^3.0",
        "symfony/http-client": "^7.0",
        "symfony/process": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Symphony\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Symphony\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/symphony"]
}
